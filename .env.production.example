# Vercel — Environment Variables (Production)
# Project: fe-lake-five.vercel.app
# Đã có sẵn trong FE/.env.production — Vercel tự đọc khi build.
# Hoặc paste vào Vercel → Settings → Environment Variables → Production (ưu tiên hơn file).

VITE_API_URL=https://histar-postgre.onrender.com
VITE_AI_URL=

VITE_DEMO_ENABLED=false
VITE_DEMO_SECRET=
VITE_DEMO_MODE=false

# Firebase Authentication (Google Sign-In) — copy API key + App ID từ Firebase Console → Web app
# Project: histar-a08c1 — paste vào FE/.env.production (gitignored) + Vercel env
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=histar-a08c1.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=histar-a08c1
VITE_FIREBASE_APP_ID=
