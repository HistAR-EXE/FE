# Copy thành .env.local nếu cần override cá nhân (file .env.local không commit).
#
# Local (npm run dev): dùng FE/.env.development — VITE_API_URL trống → proxy /api → localhost:8080
# Vercel (npm run build): dùng FE/.env.production → https://histar-postgre.onrender.com
#
# Muốn FE local gọi BE Render (test prod API):
# VITE_API_URL=https://histar-postgre.onrender.com
#
# Muốn bỏ proxy, gọi thẳng BE local:
# VITE_API_URL=http://localhost:8080
#
# Muốn bỏ proxy AI, gọi thẳng RAG service:
# VITE_AI_URL=http://localhost:8100
VITE_API_URL=
VITE_AI_URL=

# Chat full stack cần: BE :8080, AI :8100, Ollama :11434
# Chẩn đoán: powershell -File scripts/diagnose-chat.ps1
# Chi tiết: docs/TESTING.md

# Demo check-in fallback (coord with BE DEMO_ENABLED) — off on prod pitch
VITE_DEMO_ENABLED=false
VITE_DEMO_SECRET=

# Stitch quest seed cards when API returns few items — dev only
VITE_DEMO_MODE=false

# Google Maps JavaScript API (Maps JavaScript API enabled in Google Cloud)
# Restrict key to your domains (localhost + Vercel prod URL)
VITE_GOOGLE_MAPS_API_KEY=

# Firebase Authentication (Google Sign-In) — see docs/FIREBASE_AUTH_SETUP.md
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Playwright survival smoke only — real Google idToken round-trip (NOT required for local gate; AUTH-G10 uses BE test-hook fixture)
# GOOGLE_TEST_ID_TOKEN=
