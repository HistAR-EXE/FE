# Copy thành .env.local nếu cần override cá nhân (file .env.local không commit).
#
# Local (npm run dev): dùng FE/.env.development — VITE_API_URL trống → proxy /api → localhost:8080
# Vercel (npm run build): dùng FE/.env.production → https://histar-postgre.onrender.com
#
# Muốn FE local gọi BE Render (test prod API):
# VITE_API_URL=https://histar-postgre.onrender.com
#
# Muốn bỏ proxy, gọi thẳng BE local:
# VITE_API_URL=http://localhost:8080
VITE_API_URL=
VITE_AI_URL=

# Demo check-in fallback (coord with BE DEMO_ENABLED) — off on prod pitch
VITE_DEMO_ENABLED=false
VITE_DEMO_SECRET=

# Stitch quest seed cards when API returns few items — dev only
VITE_DEMO_MODE=false
