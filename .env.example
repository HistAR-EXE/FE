# Local development — leave empty to use Vite proxy (5173/api → 8080, 5173/ai → 8100)
VITE_API_URL=
VITE_AI_URL=
VITE_USE_DIRECT_AI=true

# BE-orchestrated chat (POST /api/chat/messages). Default off — enable when RAG AI :8100 is stable.
# VITE_CHAT_ORCHESTRATED=true

# Or point directly without proxy:
# VITE_API_URL=http://localhost:8080
# VITE_AI_URL=http://localhost:8100

# Production (Vercel): set to HTTPS BE host — never localhost
# VITE_API_URL=https://your-be-production.up.railway.app

# Demo check-in fallback (coord with BE DEMO_ENABLED) — off on prod pitch
VITE_DEMO_ENABLED=false
VITE_DEMO_SECRET=

# Stitch quest seed cards when API returns few items — dev only
VITE_DEMO_MODE=false
